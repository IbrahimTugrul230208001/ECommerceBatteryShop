@model ECommerceBatteryShop.Models.GuestCheckoutViewModel
@{
    ViewData["Title"] = "Misafir Girişi";
}
<main class="mx-auto max-w-lg px-4 py-10">
  <h1 class="text-2xl font-semibold text-slate-900 mb-6">Misafir Girişi</h1>
  <p class="text-sm text-slate-600 mb-6">Hesap oluşturmadan devam etmek için gerekli bilgileri doldurun.</p>

  <form asp-action="Index" method="post" class="space-y-4">
    @Html.AntiForgeryToken()

    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      <div>
        <label class="block text-sm font-medium text-slate-700">Ad</label>
        <input asp-for="Name" class="mt-1 w-full rounded-lg border border-slate-300 p-2" />
        <span asp-validation-for="Name" class="text-xs text-red-600"></span>
      </div>
      <div>
        <label class="block text-sm font-medium text-slate-700">Soyad</label>
        <input asp-for="Surname" class="mt-1 w-full rounded-lg border border-slate-300 p-2" />
        <span asp-validation-for="Surname" class="text-xs text-red-600"></span>
      </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      <div>
        <label class="block text-sm font-medium text-slate-700">E-posta</label>
        <input asp-for="Email" class="mt-1 w-full rounded-lg border border-slate-300 p-2" />
        <span asp-validation-for="Email" class="text-xs text-red-600"></span>
      </div>
      <div>
        <label class="block text-sm font-medium text-slate-700">Telefon</label>
        <input asp-for="Phone" id="phoneInput" class="mt-1 w-full rounded-lg border border-slate-300 p-2"
               placeholder="(555) 555 5555"
               maxlength="14"
               pattern="\(\d{3}\) \d{3} \d{4}"
               inputmode="tel" />
        <span asp-validation-for="Phone" class="text-xs text-red-600"></span>
      </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      <div>
        <label class="block text-sm font-medium text-slate-700">İl</label>
        <input asp-for="City" class="mt-1 w-full rounded-lg border border-slate-300 p-2" />
        <span asp-validation-for="City" class="text-xs text-red-600"></span>
      </div>
      <div>
        <label class="block text-sm font-medium text-slate-700">İlçe</label>
        <input asp-for="State" class="mt-1 w-full rounded-lg border border-slate-300 p-2" />
        <span asp-validation-for="State" class="text-xs text-red-600"></span>
      </div>
    </div>

    <div>
      <label class="block text-sm font-medium text-slate-700">Mahalle</label>
      <input asp-for="Neighbourhood" class="mt-1 w-full rounded-lg border border-slate-300 p-2" />
      <span asp-validation-for="Neighbourhood" class="text-xs text-red-600"></span>
    </div>

    <div>
      <label class="block text-sm font-medium text-slate-700">Adres</label>
      <textarea asp-for="FullAddress" rows="3" class="mt-1 w-full rounded-lg border border-slate-300 p-2"></textarea>
      <span asp-validation-for="FullAddress" class="text-xs text-red-600"></span>
    </div>

    <button type="submit" class="w-full rounded-xl bg-amber-300 px-5 py-3 font-semibold text-gray-900 hover:bg-amber-400">Devam Et</button>
  </form>
</main>

@section Scripts{
  <partial name="_ValidationScriptsPartial" />
  <script>
    (function () {
      const input = document.getElementById('phoneInput');
      if (!input) return;

      input.addEventListener('input', function (e) {
        // Strip everything except digits
        let digits = this.value.replace(/\D/g, '').slice(0, 10);
        let formatted = '';

        if (digits.length === 0) {
          formatted = '';
        } else if (digits.length <= 3) {
          formatted = '(' + digits;
        } else if (digits.length <= 6) {
          formatted = '(' + digits.slice(0, 3) + ') ' + digits.slice(3);
        } else {
          formatted = '(' + digits.slice(0, 3) + ') ' + digits.slice(3, 6) + ' ' + digits.slice(6);
        }

        this.value = formatted;
      });

      // Prevent non-numeric keypresses (allow control keys)
      input.addEventListener('keydown', function (e) {
        const allowed = [
          'Backspace', 'Delete', 'ArrowLeft', 'ArrowRight', 'Tab', 'Home', 'End'
        ];
        if (allowed.includes(e.key)) return;
        if (!/^\d$/.test(e.key)) e.preventDefault();
      });
    })();
  </script>
}
