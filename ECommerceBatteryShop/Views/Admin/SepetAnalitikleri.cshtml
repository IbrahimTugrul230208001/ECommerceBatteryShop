@model ECommerceBatteryShop.Models.AnonymousCartsViewModel
@{
    ViewData["Title"] = "Sepet Analitikleri";
    Layout = "_AdminLayout";
    var totalPages = (int)Math.Ceiling((double)Model.TotalCartCount / Model.PageSize);
    if (totalPages <= 0) totalPages = 1;
}

<div class="mx-auto max-w-7xl space-y-6">
  <header class="flex flex-col gap-4 md:flex-row md:items-center md:justify-between">
    <div>
      <p class="text-xs font-semibold uppercase tracking-wide text-slate-500">Analitik</p>
      <h1 class="text-2xl font-semibold text-slate-900">Tüm Sepetler</h1>
      <p class="text-sm text-slate-500">Aktif sepetlerin içerikleri. Toplam <strong>@Model.TotalCartCount</strong> sepet.</p>
    </div>
  </header>

  @if (!Model.Carts.Any())
  {
    <div class="rounded-2xl border border-slate-200 bg-white p-10 text-center">
      <svg xmlns="http://www.w3.org/2000/svg" class="mx-auto h-12 w-12 text-slate-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M7.2998 5H22L20 12H8.37675M21 16H9L7 3H4M4 8H2M5 11H2M6 14H2M10 20a1 1 0 1 1-2 0 1 1 0 0 1 2 0ZM21 20a1 1 0 1 1-2 0 1 1 0 0 1 2 0Z"/>
      </svg>
      <p class="mt-3 text-sm text-slate-500">Şu anda aktif sepet bulunmuyor.</p>
    </div>
  }
  else
  {
    <div class="grid gap-4">
      @foreach (var cart in Model.Carts)
      {
        <details class="group rounded-2xl border border-slate-200 bg-white overflow-hidden">
          <summary class="flex cursor-pointer items-center justify-between px-5 py-4 hover:bg-slate-50/60 transition-colors">
            <div class="flex items-center gap-4">
              <div class="flex h-10 w-10 items-center justify-center rounded-full bg-slate-100 text-sm font-bold text-slate-600">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M7.2998 5H22L20 12H8.37675M21 16H9L7 3H4M4 8H2M5 11H2M6 14H2M10 20a1 1 0 1 1-2 0 1 1 0 0 1 2 0ZM21 20a1 1 0 1 1-2 0 1 1 0 0 1 2 0Z"/>
                </svg>
              </div>
              <div>
                <div class="flex items-center gap-2">
                  <span class="text-sm font-semibold text-slate-900">@cart.Label</span>
                  @if (cart.IsAnonymous)
                  {
                    <span class="rounded-full bg-amber-100 px-2 py-0.5 text-[10px] font-semibold text-amber-700">Anonim</span>
                  }
                  else
                  {
                    <span class="rounded-full bg-emerald-100 px-2 py-0.5 text-[10px] font-semibold text-emerald-700">Üye</span>
                  }
                </div>
                <div class="text-xs text-slate-500">
                  @cart.CreatedAt.ToString("dd MMM yyyy HH:mm", new System.Globalization.CultureInfo("tr-TR"))
                  @if (!cart.IsAnonymous && !string.IsNullOrWhiteSpace(cart.UserEmail))
                  {
                    <span class="ml-1 text-slate-400">· @cart.UserEmail</span>
                  }
                </div>
              </div>
            </div>
            <div class="flex items-center gap-6">
              <div class="text-right">
                <div class="text-xs text-slate-500">Ürün</div>
                <div class="text-sm font-semibold text-slate-900">@cart.TotalItems adet</div>
              </div>
              <div class="text-right">
                <div class="text-xs text-slate-500">Toplam</div>
                <div class="text-sm font-semibold text-slate-900">$@cart.TotalValue.ToString("N2")</div>
              </div>
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-slate-400 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
              </svg>
            </div>
          </summary>

          <div class="border-t border-slate-100">
            <table class="min-w-full divide-y divide-slate-100 text-sm">
              <thead class="bg-slate-50/60 text-left text-xs font-semibold uppercase tracking-wide text-slate-500">
                <tr>
                  <th class="px-5 py-2.5">Ürün</th>
                  <th class="px-5 py-2.5">Birim Fiyat</th>
                  <th class="px-5 py-2.5">Adet</th>
                  <th class="px-5 py-2.5 text-right">Ara Toplam</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-slate-50 bg-white">
                @foreach (var item in cart.Items)
                {
                  <tr>
                    <td class="px-5 py-3">
                      <div class="flex items-center gap-3">
                        <img src="@(string.IsNullOrWhiteSpace(item.ImageUrl) ? "/img/temsili.png" : (item.ImageUrl.StartsWith("/img/") ? item.ImageUrl : "/img/" + item.ImageUrl))"
                             alt="@item.ProductName"
                             class="h-9 w-9 rounded object-cover border border-slate-200" />
                        <div>
                          <div class="font-medium text-slate-900">@item.ProductName</div>
                          <div class="text-xs text-slate-400">#@item.ProductId</div>
                        </div>
                      </div>
                    </td>
                    <td class="px-5 py-3 text-slate-700">$@item.UnitPrice.ToString("N2")</td>
                    <td class="px-5 py-3 font-medium text-slate-900">@item.Quantity</td>
                    <td class="px-5 py-3 text-right font-semibold text-slate-900">$@item.LineTotal.ToString("N2")</td>
                  </tr>
                }
              </tbody>
            </table>
          </div>
        </details>
      }
    </div>

    @* Pagination *@
    <nav class="flex items-center justify-between">
      <div class="text-xs text-slate-600">
        Toplam @Model.TotalCartCount sepet — Sayfa @Model.Page / @totalPages
      </div>
      <ul class="inline-flex overflow-hidden rounded-full border border-slate-200 text-sm">
        @{
          var prev = Model.Page > 1 ? Model.Page - 1 : 1;
          var next = Model.Page < totalPages ? Model.Page + 1 : totalPages;
        }
        <li>
          <a class="block px-4 py-2 hover:bg-slate-50 @((Model.Page==1)?"pointer-events-none opacity-50":"")"
             href="@Url.Action("SepetAnalitikleri","Admin", new { page = prev })">Önceki</a>
        </li>
        @for (var i = 1; i <= totalPages; i++)
        {
          <li>
            <a class="block px-4 py-2 hover:bg-slate-50 @(i==Model.Page?"bg-slate-900 text-white":"")"
               href="@Url.Action("SepetAnalitikleri","Admin", new { page = i })">@i</a>
          </li>
        }
        <li>
          <a class="block px-4 py-2 hover:bg-slate-50 @((Model.Page==totalPages)?"pointer-events-none opacity-50":"")"
             href="@Url.Action("SepetAnalitikleri","Admin", new { page = next })">Sonraki</a>
        </li>
      </ul>
    </nav>
  }
</div>
